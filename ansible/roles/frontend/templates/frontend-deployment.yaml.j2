apiVersion: apps/v1
kind: Deployment
metadata:
  name: healthcare-frontend
  labels:
    app: healthcare-frontend
spec:
  replicas: 2
  selector:
    matchLabels:
      app: healthcare-frontend
  template:
    metadata:
      labels:
        app: healthcare-frontend
    spec:
      containers:
        - name: healthcare-frontend
          image: {{ docker_hub_username }}/healthcare-frontend:latest
          ports:
            - containerPort: 80
          resources:
            requests:
              memory: "64Mi"
              cpu: "100m"
            limits:
              memory: "128Mi"
              cpu: "200m"
---
apiVersion: v1
kind: Service
metadata:
  name: healthcare-frontend-service
spec:
  type: NodePort
  selector:
    app: healthcare-frontend
  ports:
    - port: 80
      targetPort: 80
      nodePort: 30000
